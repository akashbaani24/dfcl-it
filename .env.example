# ============================================================
# DFCL-IT (Test System) — Environment Variables
# ============================================================

# ----- LOCAL DEVELOPMENT (SQLite) -----
# লোকাল dev-এর জন্য SQLite file ব্যবহার করুন
DATABASE_URL="file:./db/custom.db"

# ----- PRODUCTION (Turso / libSQL) -----
# Vercel-এ deploy করার সময় এই দুটো সেট করুন
# Turso dashboard থেকে নিন: https://app.turso.tech
# TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9..."

# ----- NOTES -----
# - TURSO_DATABASE_URL যদি "libsql:" দিয়ে শুরু হয় এবং TURSO_AUTH_TOKEN থাকে,
#   তাহলে app স্বয়ংক্রিয়ভাবে Turso ব্যবহার করবে।
# - অন্যথায়, এটি DATABASE_URL (local SQLite) ব্যবহার করবে।
# - Vercel-এ শুধু TURSO_DATABASE_URL আর TURSO_AUTH_TOKEN সেট করলেই হবে।
#   DATABASE_URL সেট করার দরকার নেই।
